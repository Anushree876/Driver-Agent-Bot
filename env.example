# .env — Copy this file, rename to .env, and fill in your values
# NEVER commit this file to GitHub!

# 1. Get from console.groq.com (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# 2. Path to your downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# 3. The folder ID from your Google Drive URL
# e.g. from https://drive.google.com/drive/folders/1qkx58doSeYrcLjHPDysJyVJ36PsSqqlt
# the ID is: 1qkx58doSeYrcLjHPDysJyVJ36PsSqqlt
DRIVE_FOLDER_ID=your_folder_id_here
